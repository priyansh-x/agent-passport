{
  "name": "@passport-agent/server",
  "version": "0.1.0",
  "description": "Local passport authority server for development",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "passport-agent-server": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "keywords": ["agent", "passport", "authority", "server", "ai", "authorization"],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/priyansh-x/agent-passport",
    "directory": "packages/server"
  },
  "dependencies": {
    "@passport-agent/core": "workspace:*",
    "@hono/node-server": "^2.0.6",
    "better-sqlite3": "^12.11.1",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  }
}
